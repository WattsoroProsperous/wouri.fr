<!-- CTA Section -->
<section class="cta">
    <div class="container">
        <div class="cta-layout">
            <!-- Left preview -->
            <div class="cta-preview cta-preview--left animate-on-scroll">
                <div class="cta-preview-card">
                    <img
                        src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=480&h=360&fit=crop&q=80"
                        alt="Collaboration d'équipe"
                        loading="lazy"
                    />
