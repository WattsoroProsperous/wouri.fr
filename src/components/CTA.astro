                    </a>
                </div>
            </div>

            <!-- Right preview -->
            <div class="cta-preview cta-preview--right animate-on-scroll">
                <div class="cta-preview-card">
                    <img
                        src="https://images.unsplash.com/photo-1553877522-43269d4ea984?w=480&h=360&fit=crop&q=80"
                        alt="Session de travail collaborative"
                        loading="lazy"
                    />
                    <div class="cta-preview-label">
                        <i class="fas fa-handshake"></i>
                        <span>Partenariat</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
