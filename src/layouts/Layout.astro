---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Wouri - Digital Innovation Studio | Paris',
  description = "Wouri - Studio d'innovation digitale à Paris. Ingénierie logicielle, solutions cloud et transformation digitale."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{title}</title>
    <meta name="description" content={description}>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://images.unsplash.com">

    <!-- Inter + Fira Code -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Fira+Code:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <slot />

    <script is:inline>
        // Apply saved theme or system preference immediately to prevent flash
        (function() {
            const saved = localStorage.getItem('wouri-theme');
            const theme = saved || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
            if (theme === 'light') {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>
</body>
</html>

<style is:global>
    @import '../styles/variables.css';
    @import '../styles/base.css';
    @import '../styles/animations.css';
    @import '../styles/components.css';
    @import '../styles/theme-light.css';
    @import '../styles/cookies.css';
</style>
