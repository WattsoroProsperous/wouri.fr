---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Wouri - Digital Innovation Studio | Paris',
  description = "Wouri - Studio d'innovation digitale à Paris. Ingénierie logicielle, solutions cloud et transformation digitale."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{title}</title>
    <meta name="description" content={description}>

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://images.unsplash.com">

    <!-- Modern Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&family=Fira+Code:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <!-- Theme Transition Overlay -->
    <div class="theme-transition-overlay" id="themeOverlay"></div>

    <slot />

    <script is:inline>
        // Apply saved theme immediately to prevent flash
        const savedTheme = localStorage.getItem('wouri-theme') || 'dark';
        if (savedTheme === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
        }
    </script>
</body>
</html>

<style is:global>
    @import '../styles/variables.css';
    @import '../styles/base.css';
    @import '../styles/animations.css';
    @import '../styles/components.css';
    @import '../styles/theme-light.css';
    @import '../styles/cookies.css';
</style>
